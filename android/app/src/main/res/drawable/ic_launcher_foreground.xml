<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive-icon foreground. The canvas is 108x108 but the safe zone is the
  inner 66dp (Android launchers may crop the outer ring). Content is kept
  inside x:[22..86], y:[30..78] to stay safely visible in every mask shape.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Left page -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M22,30 L54,30 L54,78 L22,78 Z" />

    <!-- Right page -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M54,30 L86,30 L86,78 L54,78 Z" />

    <!-- Spine shadow, so the two pages read as an open book -->
    <path
        android:fillColor="#C4B5FD"
        android:pathData="M53,30 L55,30 L55,78 L53,78 Z" />

    <!-- Left page text lines -->
    <path
        android:fillColor="#6D28D9"
        android:pathData="M28,40 L48,40 L48,42.5 L28,42.5 Z
                          M28,48 L48,48 L48,50.5 L28,50.5 Z
                          M28,56 L42,56 L42,58.5 L28,58.5 Z
                          M28,64 L46,64 L46,66.5 L28,66.5 Z" />

    <!-- Right page text lines -->
    <path
        android:fillColor="#6D28D9"
        android:pathData="M60,40 L80,40 L80,42.5 L60,42.5 Z
                          M60,48 L80,48 L80,50.5 L60,50.5 Z
                          M60,56 L74,56 L74,58.5 L60,58.5 Z
                          M60,64 L78,64 L78,66.5 L60,66.5 Z" />
</vector>
